{
  "name": "open-hormuz",
  "version": "1.0.0",
  "description": "Tactical escort game set in the Strait of Hormuz",
  "type": "module",
  "scripts": {
    "dev": "npx tsx server.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "npm run test && npm run build",
    "release:check": "npm run verify",
    "release:pack": "npm run build && npm pack"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pixi.js": "^8.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "terser": "^5.46.1",
    "typescript": "^5.0.0",
    "vite": "^5.4.15",
    "vitest": "^1.6.1"
  }
}
